      ],
      "assertions": [
        {
          "name": "detect-sql-injection-path",
          "type": "contains_all",
          "values": [
            "SQL injection",
            "f-string",
            "user-controlled"
          ]
        },
        {
          "name": "source-sink-evidence-contract",
          "type": "contains_all",
          "values": [
            "Evidence",
            "Source",
            "Sink",
            "Severity",
            "Fix",
            "Verify"
          ]
        },
        {
          "name": "parameterized-fix",
          "type": "contains_any",
          "values": [
            "parameterized",
            "prepared statement",
            "bind parameter"
          ]
        },
        {
          "name": "avoid-safe-parameterized-decoy",
          "type": "excludes_any",
          "values": [
            "admin stats is vulnerable",
            "parameterized query is vulnerable",
            "bind parameters are vulnerable"
          ]
        },
        {
          "name": "qualitative-review",
          "type": "judge",
          "rubric": [
            "Cite source-to-sink evidence",
            "Avoid invented findings and safe-decoy false positives",
            "Severity is calibrated",
            "Actionable fix and verification test"
          ]
        }
      ],
      "tags": [
        "baseline-smoke-discriminator"
      ]
